rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // User Validation
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'role', 'joinedAt']) 
        && data.keys().size() <= 7
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.role in ['donor', 'recipient']
        && data.joinedAt == request.time
        && (data.get('bio', '') is string && data.get('bio', '').size() <= 500)
        && (data.get('location', '') is string && data.get('location', '').size() <= 100)
        && (data.get('avatarUrl', '') is string && data.get('avatarUrl', '').size() <= 500);
    }

    // Story Validation
    function isValidStory(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'pixKey', 'createdAt', 'updatedAt', 'status'])
        && data.keys().size() <= 11
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.content is string && data.content.size() > 0 && data.content.size() <= 5000
        && data.authorId == request.auth.uid
        && data.pixKey is string && data.pixKey.size() > 0 && data.pixKey.size() <= 256
        && data.status in ['active', 'completed', 'reported']
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && (data.get('targetAmount', 0) is number && data.get('targetAmount', 0) >= 0)
        && (data.get('raisedAmount', 0) is number && data.get('raisedAmount', 0) >= 0)
        && (data.get('images', []) is list && data.get('images', []).size() <= 5);
    }

    // Donation Validation
    function isValidDonation(data) {
      return data.keys().hasAll(['storyId', 'donorId', 'amount', 'timestamp'])
        && data.keys().size() <= 8
        && data.storyId is string && isValidId(data.storyId)
        && data.donorId == request.auth.uid
        && data.amount is number && data.amount > 0
        && data.timestamp == request.time
        && (data.get('message', '') is string && data.get('message', '').size() <= 500)
        && (data.get('isPublic', true) is bool);
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if true;
      allow list: if true;
      allow create: if isVerified() && isOwner(userId) && isValidUser(incoming());
      allow update: if isVerified() && isOwner(userId) && isValidUser(incoming())
                    && incoming().joinedAt == existing().joinedAt
                    && incoming().role == existing().role;
      
      match /private/info {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && incoming().userId == userId;
      }
    }

    match /stories/{storyId} {
      allow get: if true;
      allow list: if true;
      allow create: if isVerified() && isValidStory(incoming()) && exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update: if isVerified() && (
        // Owner update: content, title, targetAmount, status
        (isOwner(existing().authorId) && isValidStory(incoming())
          && incoming().createdAt == existing().createdAt
          && incoming().authorId == existing().authorId
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'targetAmount', 'status', 'updatedAt', 'images', 'pixKey']))
        ||
        // System/Public update: raisedAmount
        (incoming().diff(existing()).affectedKeys().hasOnly(['raisedAmount', 'updatedAt'])
         && incoming().raisedAmount >= existing().raisedAmount)
      );
      allow delete: if isOwner(existing().authorId);

      match /donations/{donationId} {
        allow read: if true;
        allow create: if isVerified() && isValidDonation(incoming()) 
                      && exists(/databases/$(database)/documents/stories/$(storyId))
                      && existsAfter(/databases/$(database)/documents/stories/$(storyId));
      }
    }

    match /donations/{donationId} {
      allow read: if isVerified() && (resource.data.donorId == request.auth.uid || get(/databases/$(database)/documents/stories/$(resource.data.storyId)).data.authorId == request.auth.uid);
      allow create: if isVerified() && isValidDonation(incoming()) 
                    && exists(/databases/$(database)/documents/stories/$(incoming().storyId));
    }
  }
}
